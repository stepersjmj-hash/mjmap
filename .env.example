# ============================================================
# mjmap-proxy — 서버 보관 API 키 (.env 템플릿)
# ============================================================
# 사용법 (NAS 또는 로컬):
#   1) 이 파일을 같은 폴더에 `.env` 로 복사
#        cp .env.example .env
#   2) 아래 값을 실제 키로 채우기
#   3) docker compose up -d --build
#
# ⚠️  주의:
#   - `.env` 는 `.gitignore` 에 등록되어 있어 git 에 안 올라갑니다.
#   - 실제 키는 이 파일(.env.example)에 절대 적지 마세요.
#   - 값에 따옴표(")는 넣지 마세요 — docker compose 가 문자 그대로 사용합니다.
# ============================================================

# Opinet (한국석유공사 주유소 가격 API)
#   발급: https://www.opinet.co.kr/user/main/mainView.do → 개발자 정보 → API 키
OPINET_API_KEY=

# 경기데이터드림 (경기도 공공데이터 OpenAPI)
#   발급: https://data.gg.go.kr/portal/mainPage.do → 마이페이지 → 오픈API 인증키
GG_API_KEY=

# Kakao Local API (블루리본 식당 좌표 매칭 — scripts/geocode_bluer.py 에서만 사용)
#   발급: https://developers.kakao.com/console/app → REST API 키
#   런타임 프록시는 이 키 사용 안 함 (geocoding 은 1회성 배치 작업)
KAKAO_REST_API_KEY=
